{
  "name": "unlisted",
  "version": "1.0.0",
  "description": "Data broker removal web app — built in support of blockd.ai",
  "type": "commonjs",
  "main": "server/index.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "concurrently \"npm:dev:css\" \"npm:dev:server\"",
    "dev:server": "nodemon server/index.js",
    "dev:css": "tailwindcss -i ./public/css/input.css -o ./public/css/output.css --watch",
    "build": "npm run build:css",
    "build:css": "tailwindcss -i ./public/css/input.css -o ./public/css/output.css --minify",
    "start": "node scripts/migrate.js && node server/index.js",
    "db:migrate": "node scripts/migrate.js",
    "seed": "node server/data/seed.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-session": "^2.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "node-fetch": "^2.7.0",
    "nodemailer": "^6.9.15",
    "pg": "^8.13.1",
    "validator": "^13.12.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "better-sqlite3": "^11.3.0",
    "concurrently": "^9.0.1",
    "nodemon": "^3.1.4",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13"
  }
}
