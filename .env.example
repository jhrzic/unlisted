# Server
PORT=3000
NODE_ENV=development
SESSION_SECRET=change-this-to-a-long-random-string

# Supabase — https://supabase.com/dashboard/project/pykxmmrsecatnxxkgtbg
# Project Settings → Database → Connection string → Session pooler → URI (port 5432)
DATABASE_URL=postgresql://postgres.pykxmmrsecatnxxkgtbg:[YOUR-PASSWORD]@aws-0-us-west-2.pooler.supabase.com:5432/postgres

# Have I Been Pwned API — https://haveibeenpwned.com/API/Key
HIBP_API_KEY=

# Outbound email for sending real opt-out requests on the user's behalf.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=requests@yourdomain.com

# SQLite file path (local dev only — omit DATABASE_URL to use SQLite)
DB_PATH=./server/data/unlisted.db
