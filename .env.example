# Server
PORT=3000
NODE_ENV=development
SESSION_SECRET=change-this-to-a-long-random-string

# Have I Been Pwned API — https://haveibeenpwned.com/API/Key
# Required for the real breach-exposure check. Paid key, billed monthly.
HIBP_API_KEY=

# Outbound email for sending real opt-out requests on the user's behalf.
# Use a transactional provider (Postmark/SendGrid/SES) in production —
# these SMTP fields are for local dev/testing only.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=requests@yourdomain.com

# SQLite file path
DB_PATH=./server/data/unlisted.db
