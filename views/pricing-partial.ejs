<script>
  (function () {
    var grid = document.getElementById('pricing-grid');
    var btns = document.querySelectorAll('.billing-btn');
    btns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var mode = btn.dataset.mode;
        btns.forEach(function (b) {
          b.classList.remove('bg-bone', 'text-void', 'font-semibold');
          b.classList.add('text-steel');
        });
        btn.classList.add('bg-bone', 'text-void', 'font-semibold');
        btn.classList.remove('text-steel');

        var isAnnual = mode === 'annual';
        document.querySelectorAll('.price-annual, .billed-annual, .save-annual').forEach(function (el) {
          el.classList.toggle('hidden', !isAnnual);
        });
        document.querySelectorAll('.price-monthly, .billed-monthly').forEach(function (el) {
          el.classList.toggle('hidden', isAnnual);
        });
      });
    });
  })();
</script>

