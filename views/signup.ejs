<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head', { title: 'Sign up — Unlisted' }) %></head>
<body class="min-h-screen flex flex-col">
<%- include('partials/nav') %>

<main class="flex-1 flex items-center justify-center px-5 py-14 sm:py-20">
  <div class="w-full max-w-[420px]">
    <div class="eyebrow mb-4">CASE INTAKE</div>
    <h1 class="font-display font-extrabold uppercase text-3xl sm:text-4xl leading-tight mb-2">Open your case file.</h1>
    <p class="text-bone-dim text-sm mb-8">Free to start. We'll check your real breach exposure first.</p>

    <% if (error) { %>
      <div class="border border-signal/40 bg-signal/10 text-sm text-bone px-4 py-3 mb-6 font-mono">⚠ <%= error %></div>
    <% } %>

    <form action="/signup" method="POST" class="flex flex-col gap-4">
      <div>
        <label class="tag-mono text-steel block mb-2">Full name</label>
        <input type="text" name="full_name" class="input-field" placeholder="Jordan Martinez" required>
      </div>
      <div>
        <label class="tag-mono text-steel block mb-2">Email</label>
        <input type="email" name="email" class="input-field" placeholder="you@example.com" required>
      </div>
      <div>
        <label class="tag-mono text-steel block mb-2">Password</label>
        <input type="password" name="password" class="input-field" placeholder="At least 8 characters" minlength="8" required>
      </div>
      <div>
        <label class="tag-mono text-steel block mb-2">State (optional)</label>
        <select name="state" class="input-field">
          <option value="">Select your state</option>
          <option value="CA">California</option>
          <option value="NY">New York</option>
          <option value="TX">Texas</option>
          <option value="FL">Florida</option>
          <option value="other">Other</option>
        </select>
        <p class="font-mono text-[11px] text-steel mt-2">California residents get access to the state-run DROP deletion platform.</p>
      </div>
      <button type="submit" class="btn-primary mt-2">Create my case file →</button>
    </form>

    <p class="text-sm text-bone-dim mt-6 text-center">Already have an account? <a href="/login" class="text-bone underline">Log in</a></p>
  </div>
</main>

<%- include('partials/footer') %>
</body>
</html>
