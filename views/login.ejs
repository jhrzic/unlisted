<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head', { title: 'Log in — Unlisted' }) %></head>
<body class="min-h-screen flex flex-col">
<%- include('partials/nav') %>

<main class="flex-1 flex items-center justify-center px-5 py-14 sm:py-20">
  <div class="w-full max-w-[420px]">
    <div class="eyebrow mb-4">ACCESS</div>
    <h1 class="font-display font-extrabold uppercase text-3xl sm:text-4xl leading-tight mb-2">Welcome back.</h1>
    <p class="text-bone-dim text-sm mb-8">Log in to check your case status.</p>

    <% if (error) { %>
      <div class="border border-signal/40 bg-signal/10 text-sm text-bone px-4 py-3 mb-6 font-mono">⚠ <%= error %></div>
    <% } %>

    <form action="/login" method="POST" class="flex flex-col gap-4">
      <div>
        <label class="tag-mono text-steel block mb-2">Email</label>
        <input type="email" name="email" class="input-field" placeholder="you@example.com" required>
      </div>
      <div>
        <label class="tag-mono text-steel block mb-2">Password</label>
        <input type="password" name="password" class="input-field" placeholder="Your password" required>
      </div>
      <button type="submit" class="btn-primary mt-2">Log in →</button>
    </form>

    <p class="text-sm text-bone-dim mt-6 text-center">No account yet? <a href="/signup" class="text-bone underline">Sign up</a></p>
  </div>
</main>

<%- include('partials/footer') %>
</body>
</html>
